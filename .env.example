# ============================================================
# MAAV / VAANI — Environment Variables Template
# Copy this file to .env and fill in real values locally.
# In production, set these in Render / Vercel dashboards —
# NEVER commit a .env file with real keys.
# ============================================================

# ---- LLM Providers (Backend service) ----
GROK_API_KEY=your_groq_api_key_here
GROK_BASE_URL=https://api.groq.com/openai/v1
GROK_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Speech (Speech Gateway service) ----
SARVAM_API_KEY=your_sarvam_api_key_here

# Azure fallback TTS — needed for Assamese / Urdu
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ---- Security (Backend service) ----
# Auth is Supabase-issued JWTs (Google OAuth), signed asymmetrically (ES256)
# by default on current Supabase projects — SUPABASE_URL is used to derive
# the JWKS endpoint (auth/v1/.well-known/jwks.json) that verifies them.
# JWT_SIGNING_SECRET/JWT_AUDIENCE stay as a fallback for older HS256-secret
# projects (only used when SUPABASE_URL is unset).
SUPABASE_URL=https://your-project.supabase.co
JWT_AUDIENCE=authenticated
JWT_SIGNING_SECRET=change-me-to-a-long-random-secret

# ---- CORS — set to your Vercel frontend URL in production ----
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# ---- Databases (Backend service) ----
# Supabase's Postgres connection string (Settings -> Database -> Connection
# string -> Session pooler URI). Chat history persistence, see
# agent_core/persistence/chat_store.py.
REDIS_URL=redis://localhost:6379/0
POSTGRES_DSN=postgresql://maav:maav@localhost:5432/maav

# ---- RAG (Backend service) ----
# Free Hugging Face account -> Settings -> Access Tokens -> new "Read" token.
# Used for BAAI/bge-m3 embeddings (agent_core/rag/embeddings.py) — both
# ingestion (scripts/ingest_rag_chunks.py) and live retrieval. Requires
# POSTGRES_DSN above too (embeddings are stored via pgvector — see
# docs/supabase_schema.sql's rag_chunks table). Leave unset to disable RAG
# entirely; the assistant answers normally without it.
HF_API_TOKEN=hf_your_token_here

# ---- Supabase (Frontend service — Vercel) ----
# Settings -> API on the Supabase project. Safe to expose client-side (RLS
# enforces per-user access, not this key).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
